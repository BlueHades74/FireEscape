  sprite: {fileID: -8579194870694823066, guid: 161c891a229f09641973cda0ad2d328e, type: 3}
  npcName: NPC_NAME
  npcDialog:
  - "Hey, it\u2019s you again! Good timing! The steps are ablaze and I\u2019m stuck
    on stage!"
  - "Sorry for the trouble again, I got lost in my song and didn\u2019t notice\u2026"
  playerResponseDialog:
  - "M-Mr. Oliver!? Stay right there, I\u2019ll come around the side!"
  - HELLO!! Glad we made it to you before the flame did, friend!
  - "W-Well, at least you weren\u2019t drunk, Mr. Oliver\u2026"
  - "I wish I coulda been there for your performance, Mr. Oliver\u2026"
  interactableDistace: 7
  questTarget: {fileID: 0}
  turnInRange: 3
