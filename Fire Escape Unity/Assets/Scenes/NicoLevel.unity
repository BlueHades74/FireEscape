    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'npcDialog.Array.data[0]'
      value: "Hey, it\u2019s you again! Good timing! The steps are ablaze and I\u2019m
        stuck on stage!"
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'npcDialog.Array.data[1]'
      value: "Sorry for the trouble again, I got lost in my song and didn\u2019t
        notice\u2026"
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'playerResponseDialog.Array.data[0]'
      value: "M-Mr. Oliver!? Stay right there, I\u2019ll come around the side!"
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'playerResponseDialog.Array.data[1]'
      value: HELLO!! Glad we made it to you before the flame did, friend!
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'playerResponseDialog.Array.data[2]'
      value: "W-Well, at least you weren\u2019t drunk, Mr. Oliver\u2026"
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'playerResponseDialog.Array.data[3]'
      value: "I wish I coulda been there for your performance, Mr. Oliver\u2026"
      objectReference: {fileID: 0}
