      value: 6
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'npcDialog.Array.data[0]'
      value: "Ahhh, this date is so romantic\u2026 so much candlelight\u2026~"
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'npcDialog.Array.data[1]'
      value: "Ah\u2026 Evelyn\u2026! I never knew you were this strong~!"
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'playerResponseDialog.Array.data[0]'
      value: "(Oh god, that guy\u2019s gone over the edge with the rams!)"
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'playerResponseDialog.Array.data[1]'
      value: "Sittin\u2019 spiffy and for what, eh? Fire\u2019s a flat tire, she
        is."
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'playerResponseDialog.Array.data[2]'
      value: "Um- I\u2019m not your squeeze, sorry\u2026"
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'playerResponseDialog.Array.data[3]'
      value: "(If Evelyn is so strong\u2026 I\u2019d like to arm wrestle her!)"
      objectReference: {fileID: 0}
