    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: interactableDistace
      value: 6
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'npcDialog.Array.data[0]'
      value: Help! I trapped myself in this fridge! I thought the cold would protect
        me!
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'npcDialog.Array.data[1]'
      value: "Oh, thank yo\u2014 YIKES! It\u2019s hotsy-totsy out here!"
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'playerResponseDialog.Array.data[0]'
      value: "\u2026Er, what!? Why did you think that would work!?"
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'playerResponseDialog.Array.data[1]'
      value: "Using the cold to protect against the hot\u2026 you wise head!!"
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'playerResponseDialog.Array.data[2]'
      value: "(I don\u2019t think he knows what that hotsy-totsy means\u2014)"
      objectReference: {fileID: 0}
    - target: {fileID: 5423119197627558984, guid: 2dbc2d36194f4694fb809b9795b48038, type: 3}
      propertyPath: 'playerResponseDialog.Array.data[3]'
      value: "That\u2019s an awesome word. I wanna say that from now on!"
      objectReference: {fileID: 0}
