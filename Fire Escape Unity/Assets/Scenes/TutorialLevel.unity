--- !u!1001 &1647656724
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 19810275}
    m_Modifications:
    - target: {fileID: 3424642299102713754, guid: 9681dd3a94eeae548a3615036587387d, type: 3}
      propertyPath: lines.Array.size
      value: 5
      objectReference: {fileID: 0}
    - target: {fileID: 3424642299102713754, guid: 9681dd3a94eeae548a3615036587387d, type: 3}
      propertyPath: 'lines.Array.data[0]'
      value: 'Captain: "Welcome, fresh meat! You people are going to be shown a thing
        or two that we''ve seen in the field.'
      objectReference: {fileID: 0}
    - target: {fileID: 3424642299102713754, guid: 9681dd3a94eeae548a3615036587387d, type: 3}
      propertyPath: 'lines.Array.data[1]'
      value: 'Captain: "That big piece of furniture over there is something that''s
        going to require teamwork to get past. Get on both sides and press the use
        button and move that sucker out of the way!"'
      objectReference: {fileID: 0}
    - target: {fileID: 3424642299102713754, guid: 9681dd3a94eeae548a3615036587387d, type: 3}
      propertyPath: 'lines.Array.data[2]'
      value: 'Captain: "Money''s been tight so some of our technology is a bit primitive.
        That water bucket should be used to put out fires! Refill back at the truck!'
      objectReference: {fileID: 0}
    - target: {fileID: 3424642299102713754, guid: 9681dd3a94eeae548a3615036587387d, type: 3}
      propertyPath: 'lines.Array.data[3]'
      value: 'Captain: "And of course we got you an axe to break down any debris
        in your way or any doors that won''t budge."'
      objectReference: {fileID: 0}
    - target: {fileID: 3424642299102713754, guid: 9681dd3a94eeae548a3615036587387d, type: 3}
      propertyPath: 'lines.Array.data[4]'
      value: 'Captain: "Now let''s see what you got!"'
      objectReference: {fileID: 0}
    - target: {fileID: 3588303609251993506, guid: 9681dd3a94eeae548a3615036587387d, type: 3}
      propertyPath: m_Pivot.x
