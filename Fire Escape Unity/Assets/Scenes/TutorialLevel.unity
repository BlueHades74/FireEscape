      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 1444632608957252962, guid: 336e797cb57630446a065ba6caa41fb4, type: 3}
      propertyPath: linesOnLoad.Array.size
      value: 5
      objectReference: {fileID: 0}
    - target: {fileID: 1444632608957252962, guid: 336e797cb57630446a065ba6caa41fb4, type: 3}
      propertyPath: 'linesOnLoad.Array.data[0]'
      value: 'Captain: Welcome, fresh meat!^ You are going to be shown a thing or
        two about field work.'
      objectReference: {fileID: 0}
    - target: {fileID: 1444632608957252962, guid: 336e797cb57630446a065ba6caa41fb4, type: 3}
      propertyPath: 'linesOnLoad.Array.data[1]'
      value: 'Captain: That big piece of furniture over there is something that''s
        going to require teamwork to get past.^ Get on both sides,^ press the use
        button,^ and move that sucker out of the way!'
      objectReference: {fileID: 0}
    - target: {fileID: 1444632608957252962, guid: 336e797cb57630446a065ba6caa41fb4, type: 3}
      propertyPath: 'linesOnLoad.Array.data[2]'
      value: 'Captain: Money''s been tight,^ so we don''t have much fancy new equipment.^
        That water bucket should be used to put out fires!^ You can refill it at
